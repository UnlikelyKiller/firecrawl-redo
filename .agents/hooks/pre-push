#!/bin/sh

# ChangeGuard Pre-Push Enforcement Hook
# Ensures that all changes are reconciled and committed via ChangeGuard ledger before pushing.

echo "--- ChangeGuard Workflow Check ---"

# 1. Check for uncommitted git changes
if ! git diff-index --quiet HEAD --; then
    echo "❌ PUSH REJECTED: Uncommitted Changes Detected"
    echo "You must commit your changes and record them in the ChangeGuard ledger first."
    exit 1
fi

# 2. Refresh state
changeguard scan > /dev/null 2>&1

# 2. Check status
STATUS=$(changeguard ledger status --compact 2>/dev/null)

# Extract counts using grep/sed
PENDING=$(echo "$STATUS" | grep -o "[0-9]* pending" | cut -d' ' -f1)
DRIFT=$(echo "$STATUS" | grep -o "[0-9]* unaudited drift" | cut -d' ' -f1)

# Default to 0 if extraction fails
PENDING=${PENDING:-0}
DRIFT=${DRIFT:-0}

if [ "$PENDING" -gt 0 ] || [ "$DRIFT" -gt 0 ]; then
    echo "❌ PUSH REJECTED: ChangeGuard Workflow Violation"
    echo "--------------------------------------------------"
    echo "You have $PENDING pending transactions and $DRIFT unaudited drift entries."
    echo ""
    echo "Required Workflow:"
    echo "1. changeguard ledger status -- (To see what's missing)"
    echo "2. changeguard ledger commit -- (To finish tracks)"
    echo "3. changeguard ledger reconcile -- (To accept intentional drift)"
    echo "--------------------------------------------------"
    exit 1
fi

# 3. Verify CI Gate (Optional but recommended for agents)
echo "Running ChangeGuard Verification..."
if ! changeguard verify > /dev/null 2>&1; then
    echo "❌ PUSH REJECTED: ChangeGuard Verification Failed"
    echo "The CI Gate (fmt/clippy/test) must pass before pushing."
    echo "Run 'changeguard verify' to see errors."
    exit 1
fi

echo "✅ ChangeGuard: All changes reconciled and verified."
exit 0
